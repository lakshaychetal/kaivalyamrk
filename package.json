{
  "name": "kaivalyam-homestay-website",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing-and-booking website for Kaivalyam Homestay, a pet-friendly hill-village homestay in Padichira, Wayanad, Kerala.",
  "scripts": {
    "dev": "next dev",
    "build:assets": "node scripts/build-assets.mjs && node scripts/validate-assets.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "prebuild": "npm run build:assets",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:e2e": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
